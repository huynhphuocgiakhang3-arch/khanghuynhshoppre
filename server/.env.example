# ===== SERVER CONFIG =====
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ===== DATABASE =====
MONGO_URI=mongodb://127.0.0.1:27017/khanghuynh_shop

# ===== JWT =====
JWT_SECRET=thay_doi_chuoi_bi_mat_nay_thanh_chuoi_ngau_nhien_dai
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=thay_doi_chuoi_bi_mat_refresh_nay_cung_phai_random
JWT_REFRESH_EXPIRES_IN=30d

# ===== ADMIN SEED (dung 1 lan duy nhat khi seed) =====
ADMIN_EMAIL=admin@khanghuynh.shop
ADMIN_PASSWORD=DoiMatKhauNganNgay123!
ADMIN_USERNAME=superadmin

# ===== NODEMAILER (Gmail App Password hoac SMTP khac) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Khanghuynh.shop

# ===== VIETQR (khong can key, dung chuan cong khai) =====
VIETQR_BANK_BIN=970436
VIETQR_ACCOUNT_NO=0123456789
VIETQR_ACCOUNT_NAME=NGUYEN VAN A
VIETQR_TEMPLATE=compact2

# ===== CLOUDINARY (luu tru anh san pham va file giao cho khach) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== PAYMENT GATEWAY (SePay / Casso / PayOS - dien sau khi dang ky) =====
# Day la cau hinh mau, gia tri thuc te se duoc luu trong SystemConfig (DB)
# va co the sua truc tiep tren trang Admin, khong can sua file .env
PAYMENT_PROVIDER=manual
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# ===== RATE LIMIT =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ===== TELEGRAM BOT (thong bao cho Admin khi co the cao/nap QR can duyet) =====
# KHONG commit gia tri that cua TELEGRAM_BOT_TOKEN len GitHub - chi dien vao
# file .env that (da duoc .gitignore) tren may/server that su cua ban.
# Lay TELEGRAM_CHAT_ID bang cach: nhan tin bat ky cho bot cua ban trong Telegram,
# sau do mo trinh duyet: https://api.telegram.org/bot<TOKEN>/getUpdates
# roi tim gia tri "chat":{"id": ...} trong ket qua tra ve.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_URL=http://localhost:3000/admin
