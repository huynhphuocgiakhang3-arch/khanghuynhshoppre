# ===== PAYMENT GATEWAY (SePay / Casso / PayOS - dien sau khi dang ky) =====
# Day la cau hinh mau, gia tri thuc te se duoc luu trong SystemConfig (DB)
# va co the sua truc tiep tren trang Admin, khong can sua file .env
PAYMENT_PROVIDER=manual
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# ===== BANK_TOKEN - Kiem tra thanh toan VietQR CHU DONG (polling qua SePay) =====
# Dung cho tinh nang moi: khi khach quet QR va bam "Da thanh toan", frontend
# se TU DONG hoi lai server moi 5s (GET /api/check-payment) de kiem tra da
# co tien chua - server se dung token nay de goi API cua SePay xem lich su
# giao dich ngan hang.
#
# Cach lay BANK_TOKEN (mien phi, khong can dang ky dich vu tra phi):
# 1. Vao https://my.sepay.vn/register dang ky tai khoan SePay.
# 2. Lien ket tai khoan ngan hang THAT cua ban (TPBank, STK 10002181284)
#    voi SePay (theo huong dan tren my.sepay.vn - thuong chi mat vai phut,
#    khong can lien he ngan hang).
# 3. Vao my.sepay.vn -> "Cau hinh Cong ty" -> "API Access" -> bam
#    "+ Them API" de tao Token moi, dat ten tuy y (vd "Khanghuynh Shop").
# 4. Copy Token vua tao, dan vao gia tri ben duoi.
# KHONG BAO GIO dua Token nay vao code frontend hay commit len GitHub.
BANK_TOKEN=

# ===== RATE LIMIT =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# ===== TELEGRAM BOT (thong bao cho Admin khi co the cao/nap QR can duyet) =====
# KHONG commit gia tri that cua TELEGRAM_BOT_TOKEN len GitHub - chi dien vao
# file .env that (da duoc .gitignore) tren may/server that su cua ban.
# Lay TELEGRAM_CHAT_ID bang cach: nhan tin bat ky cho bot cua ban trong Telegram,
# sau do mo trinh duyet: https://api.telegram.org/bot<TOKEN>/getUpdates
# roi tim gia tri "chat":{"id": ...} trong ket qua tra ve.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_URL=http://localhost:3000/admin

# ===== BAO MAT NANG CAO CHO ADMIN =====

# 1) IP WHITELIST - chi cac IP trong danh sach nay (cach nhau boi dau phay,
#    KHONG co khoang trang) moi truy cap duoc /api/admin/* VA dang nhap duoc
#    dung username admin (xem RESERVED_ADMIN_USERNAME trong auth.controller.js).
#    De TRONG = khong chan ai (mac dinh, tranh tu khoa minh khi moi deploy).
#    Cach xem IP hien tai cua ban: mo https://whatismyip.com
#    LUU Y: nha mang Viet Nam thuong cap IP DONG (thay doi theo thoi gian) -
#    neu bi khoa nham sau khi doi IP, vao lai bien nay tren host va sua.
ADMIN_ALLOWED_IPS=

# 2) MA PIN BAO MAT - buoc thu 2 khi dang nhap tai khoan Admin (sau khi
#    nhap dung mat khau), VA dung de mo khoa man hinh sau 5 phut khong thao
#    tac. Nen la 1 day SO DAI (vd 12-20 so), CHI MINH BAN BIET, khong ghi ra
#    giay/luu tren may nguoi khac. Doi dinh ky de tang bao mat.
ADMIN_SECURITY_PIN=

# 3) MA TOTP RESET MAT KHAU - bat buoc nhap dung ma 6 so nay (doi moi 30s,
#    giong Google Authenticator) truoc khi Admin duoc phep reset mat khau
#    bat ky user nao. Cach thiet lap:
#    - Gia tri Base32 mau (HAY TU TAO GIA TRI RIENG, dung lai gia tri mau
#      duoi day la KHONG an toan vi da xuat hien trong tai lieu nay):
#      WKAJPKHR6SFVLC53FNZSWD3FQNYVL7KP
#    - Mo app Google Authenticator / Authy tren dien thoai -> "Nhap ma thiet
#      lap thu cong" -> dien Base32 secret o tren, ten tuy y (vd "Khanghuynh
#      Admin Reset") -> app se hien ma 6 so, tu doi moi 30s.
#    - De TU TAO secret rieng an toan hon, chay lenh sau tren may co Node.js
#      (chi can chay 1 LAN duy nhat luc thiet lap):
#      node -e "console.log(require('./server/src/utils/totp').generateBase32Secret())"
ADMIN_RESET_TOTP_SECRET=
